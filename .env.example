# Copy to .env.local — NEVER commit .env.local or real secrets to Git.

# Supabase (required for production — set these in Vercel too)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Server-side only — never expose in the browser or commit to Git
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Portal passwords for npm run db:auth-bootstrap (choose strong unique values)
AUTH_PASSWORD_ADMIN=__set_in_env_local__
AUTH_PASSWORD_SALES=__set_in_env_local__
AUTH_PASSWORD_PPF=__set_in_env_local__

# Optional: local demo login without Supabase Auth (development only)
# VITE_ALLOW_DEMO_AUTH=true
# VITE_DEMO_PASSWORD_ADMIN=
# VITE_DEMO_PASSWORD_SALES=
# VITE_DEMO_PASSWORD_PPF=

# Optional: credentials for UI/QA test scripts (local only)
# AUTH_ADMIN_EMAIL=admin@marvelx.pk
# AUTH_SALES_EMAIL=sales@marvelx.pk
# AUTH_PPF_EMAIL=ppf@marvelx.pk
