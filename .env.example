# Copy to .env.local and fill in values from Supabase Dashboard → Settings → API
#
# Vercel production: add the same VITE_* variables in
# Project Settings → Environment Variables (Production + Preview),
# then redeploy — Vite bakes them in at build time.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional legacy aliases
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only — scripts / CI only, NEVER in client code
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# One-time auth bootstrap (npm run db:auth-bootstrap) — min 12 characters each
AUTH_PASSWORD_ADMIN=
AUTH_PASSWORD_SALES=
AUTH_PASSWORD_PPF=

# Optional: UI test scripts (ui:edit-check, ui:create-check)
AUTH_ADMIN_EMAIL=admin@marvelx.pk
AUTH_SALES_EMAIL=sales@marvelx.pk

# Local dev only — enables mock login without Supabase Auth (never in production)
# VITE_ALLOW_DEMO_AUTH=true
