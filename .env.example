# Supabase (required for production)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Server-side only — never commit real values
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Portal passwords for npm run db:auth-bootstrap
AUTH_PASSWORD_ADMIN=choose-a-strong-password
AUTH_PASSWORD_SALES=sales123
AUTH_PASSWORD_PPF=ppf123

# Optional: local demo login without Supabase Auth (dev only)
# VITE_ALLOW_DEMO_AUTH=true
